filters:
  and:
    - file.inFolder("wiki/entities")
properties:
  file.name:
    displayName: Entity
  note.tags:
    displayName: Tags
  note.summary:
    displayName: Summary
  note.tier:
    displayName: Tier
  note.updated:
    displayName: Updated
views:
  - type: cards
    name: Entities
    limit: 100
    order:
      - file.name
      - tags
      - summary
      - tier
      - updated
